{
	"$schema": "https://raw.githubusercontent.com/ow-mods/owml/master/schemas/config_schema.json",
	"enabled": true,
	"settings": {
		"Count Up": true,
		"Count In Milliseconds": false,
		"Events to Display": 5,
		"Only Display When Suit Equipped": false,
		"HudScale": {
			"title": "事件列表宽度",
			"type": "slider",
			"value": 20,
			"min": 10,
			"max": 80
		},
		"Sun": {
			"title": "展示太阳活动",
			"type": "toggle",
			"value": true,
			"yes": "Yes",
			"no": "No"
		},
		"TimeLoop": {
			"title": "展示时间循环事件",
			"type": "toggle",
			"value": true,
			"yes": "Yes",
			"no": "No"
		},
		"WarpPlatforms": {
			"title": "展示传送平台事件",
			"type": "toggle",
			"value": true,
			"yes": "Yes",
			"no": "No"
		},
		"Chert": {
			"title": "展示 Chert 的情绪",
			"type": "toggle",
			"value": true,
			"yes": "Yes",
			"no": "No"
		},
		"Misc": {
			"title": "展示其他事件",
			"type": "toggle",
			"value": true,
			"yes": "Yes",
			"no": "No"
		},
		"EotE": {
			"title": "展示眼之回响(DLC)事件",
			"type": "toggle",
			"value": true,
			"yes": "Yes",
			"no": "No"
		}
	}
}